# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com
# Go to Project Settings → API to find your URL and keys

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Vercel Blob Storage (optional, for file uploads)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the values with your actual Supabase credentials
# 3. You can find your credentials in the Supabase dashboard:
#    - Go to Project Settings
#    - Click on "API" in the left sidebar
#    - Copy "Project URL" and the API keys
# 4. Restart the development server after setting up the .env.local file
